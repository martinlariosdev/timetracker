{
  "name": "timetrack-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TimeTrack mobile and backend monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "tsx scripts/verify-structure.test.ts && turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "mobile": "pnpm --filter @timetrack/mobile",
    "backend": "pnpm --filter @timetrack/backend"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "tsx": "^4.7.1",
    "turbo": "^1.12.4",
    "typescript": "^5.9.2"
  }
}
