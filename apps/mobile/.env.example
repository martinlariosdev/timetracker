# Okta Authentication Configuration
# Copy this file to .env and fill in your Okta application credentials

# Okta Issuer URL
# Format: https://<your-okta-domain>/oauth2/default
# Example: https://dev-12345.okta.com/oauth2/default
EXPO_PUBLIC_OKTA_ISSUER=https://dev-example.okta.com/oauth2/default

# Okta Client ID
# Get this from your Okta application settings
EXPO_PUBLIC_OKTA_CLIENT_ID=your-client-id-here

# Okta Redirect URI
# For development with Expo: exp://localhost:8081
# For production: Your custom scheme (e.g., timetrack://auth/callback)
EXPO_PUBLIC_OKTA_REDIRECT_URI=exp://localhost:8081
